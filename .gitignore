# Evaluation harness: raw serial captures (may be large / site-specific) and
# regenerated result artifacts. Keep the folder placeholders.
evaluation/logs/*
!evaluation/logs/.gitkeep
evaluation/results/*
!evaluation/results/.gitkeep
