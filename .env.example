# ── Firebase web app config ─────────────────────────────────────────────────
# From Firebase console → Project settings → Your apps → Web app.
# These are safe to ship to the client: they identify the project, they do not
# grant access. Access control lives in database.rules.json / firestore.rules.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ── Web app behaviour ────────────────────────────────────────────────────────
# true → run fully on simulated data + mock auth (demo/dev without a device).
# Leaving the VITE_FIREBASE_* keys above empty has the same effect.
VITE_DEMO=false

# Building capacity in watts — the load gauge's 100% mark.
VITE_CAPACITY_W=12000

# Electricity tariff in ₦ per kWh (display only; the ESP32 computes the
# authoritative costNaira with its own copy of this constant).
VITE_TARIFF_NAIRA_PER_KWH=68

# ── Seed script (scripts/seed.mjs) ───────────────────────────────────────────
# Only needed when seeding a LIVE project; the emulator needs no credentials.
# GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json
# FIREBASE_DATABASE_URL=https://<project>-default-rtdb.firebaseio.com

# Account overrides (defaults are for local/emulator use — change for real
# deployments):
# SEED_ADMIN_EMAIL=admin@hems.local
# SEED_ADMIN_PASSWORD=change-me
# SEED_USER_EMAIL=user@hems.local
# SEED_USER_PASSWORD=change-me
# SEED_DEVICE_EMAIL=device@hems.local
# SEED_DEVICE_PASSWORD=change-me
